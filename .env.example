# Copy to .env and fill in. Loaded by the CLI via python-dotenv.

# Required — reasoning, grading, and photo/whiteboard vision.
# Get one at https://console.anthropic.com  (Settings -> API keys)
ANTHROPIC_API_KEY=sk-ant-...

# Optional — enables voice input (/voice and /record). Speech-to-text only.
# Get one free ($200 credit) at https://console.deepgram.com
DEEPGRAM_API_KEY=

# Optional — product analytics (web app). Tracks visitors, clicks, and the
# interview funnel in PostHog. The project key is publishable (write-only), so
# it is safe in the browser. Get yours: PostHog -> Settings -> Project API key.
# One key serves ALL experiments — events carry an `experiment` property
# (tutor / arena / recruiter / referrals) so dashboards stay separate.
PMCP_POSTHOG_KEY=
# PMCP_POSTHOG_HOST=https://us.i.posthog.com

# Shared login (arena + recruiter). Two passwordless doors; enable either or both.
# Google: console.cloud.google.com -> APIs & Services -> Credentials -> Create
# OAuth client ID (Web application). Add your domains (and http://localhost:8000)
# under "Authorized JavaScript origins". The client id is PUBLIC by design.
PMCP_GOOGLE_CLIENT_ID=
# Email codes: resend.com -> API Keys (free tier: 100 emails/day). Without a
# verified domain, Resend sends from onboarding@resend.dev — fine to start.
PMCP_RESEND_KEY=
# PMCP_EMAIL_FROM=PM Case Prep <login@yourdomain.com>

# Recruiter copilot experiment
# PMCP_RECRUITER_MODEL=claude-sonnet-5   # one call per recruiter message
# PMCP_RECRUITER_HOURLY_PER_IP=40        # chat calls per IP per hour
# PMCP_AUTH_HOURLY_PER_IP=20             # login attempts per IP per hour

# Optional overrides
# PMCP_INTERVIEWER_MODEL=claude-sonnet-5  # fast model for conversational turns
# PMCP_GRADER_MODEL=claude-opus-4-8       # deep model for end-of-case grading
# PMCP_MODEL=                             # set to override BOTH at once
# PMCP_SILENCE_S=5.0        # pause (s) before thinking-out-loud commits
# PMCP_QUESTION_S=1.5       # pause (s) before a direct question commits
# PMCP_MIN_CONFIDENCE=0.6   # drop utterances below this transcription confidence

# Abuse guards (web app; defaults are sane — tune only if needed)
# PMCP_MAX_SESSIONS=25          # concurrent interviews, global
# PMCP_MAX_SESSIONS_PER_IP=4    # concurrent interviews per IP
# PMCP_MAX_SESSIONS_PER_UID=2   # concurrent interviews per visitor cookie
# PMCP_WS_HOURLY_PER_IP=30      # new sessions per IP per hour
# PMCP_LOGIN_HOURLY_PER_IP=10   # /api/login attempts per IP per hour
# PMCP_MAX_TURNS=80             # model calls per session before auto-grade
# PMCP_MAX_SESSION_MIN=90       # hard session length cap (minutes)
# PMCP_IDLE_MIN=15              # no audio/typing for this long -> wind down
# PMCP_MAX_TEXT_CHARS=8000      # typed turn length cap
# PMCP_DEV_DOCS=1               # local only: re-enable /docs + verbose /health

# Speech-to-text turn detection. Default is Deepgram Flux — native SEMANTIC
# end-of-turn detection (knows a thinking pause from a finished thought), which
# is what an interview needs. Auto-falls back to nova-3 if your account lacks
# Flux. Set PMCP_STT=nova to force the classic silence-timer model instead.
# PMCP_STT=nova
# PMCP_FLUX_EOT=0.8         # 0-1; higher = MORE patient before ending a turn
# PMCP_SILENCE_S=2.5        # nova-3 only: pause (s) before a turn commits
