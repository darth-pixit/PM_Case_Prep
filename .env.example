# Copy to .env and fill in. Loaded by the CLI via python-dotenv.

# Required — reasoning, grading, and photo/whiteboard vision.
# Get one at https://console.anthropic.com  (Settings -> API keys)
ANTHROPIC_API_KEY=sk-ant-...

# Optional — enables voice input (/voice and /record). Speech-to-text only.
# Get one free ($200 credit) at https://console.deepgram.com
DEEPGRAM_API_KEY=

# Optional — product analytics (web app). Tracks visitors, clicks, and the
# interview funnel in PostHog. The project key is publishable (write-only), so
# it is safe in the browser. Get yours: PostHog -> Settings -> Project API key.
PMCP_POSTHOG_KEY=
# PMCP_POSTHOG_HOST=https://us.i.posthog.com

# Optional overrides
# PMCP_INTERVIEWER_MODEL=claude-sonnet-5  # fast model for conversational turns
# PMCP_GRADER_MODEL=claude-opus-4-8       # deep model for end-of-case grading
# PMCP_MODEL=                             # set to override BOTH at once
# PMCP_SILENCE_S=5.0        # pause (s) before thinking-out-loud commits
# PMCP_QUESTION_S=1.5       # pause (s) before a direct question commits
# PMCP_MIN_CONFIDENCE=0.6   # drop utterances below this transcription confidence

# Speech-to-text turn detection. Default is Deepgram Flux — native SEMANTIC
# end-of-turn detection (knows a thinking pause from a finished thought), which
# is what an interview needs. Auto-falls back to nova-3 if your account lacks
# Flux. Set PMCP_STT=nova to force the classic silence-timer model instead.
# PMCP_STT=nova
# PMCP_FLUX_EOT=0.8         # 0-1; higher = MORE patient before ending a turn
# PMCP_SILENCE_S=2.5        # nova-3 only: pause (s) before a turn commits
